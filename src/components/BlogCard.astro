---
import { Image } from 'astro:assets';
import FormattedDate from './FormattedDate.astro';
import Tag from './Tag.astro';

interface Props {
	title: string;
	description: string;
	href: string;
	date: Date;
	tags?: string[];
	readingTime?: string;
	image?: any;
	featured?: boolean;
}

const {
	title,
	description,
	href,
	date,
	tags = [],
	readingTime = '1 min read',
	image,
	featured = false,
} = Astro.props;
---

<article
	class:list={[
		'group panel h-full overflow-hidden transition duration-300 hover:-translate-y-1 hover:border-cyan-400/30',
		featured ? 'lg:col-span-2' : '',
	]}
>
	<a href={href} class:list={['grid h-full', featured ? 'lg:grid-cols-[1.1fr_0.9fr]' : 'grid-cols-1']}>
		{image && (
			<div class="relative min-h-64 overflow-hidden">
				<Image
					src={image}
					alt={title}
					widths={[480, 720, 960]}
					sizes={featured ? '(min-width: 1024px) 50vw, 100vw' : '(min-width: 768px) 33vw, 100vw'}
					class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
				/>
				<div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/30 to-transparent"></div>
			</div>
		)}

		<div class="flex h-full flex-col justify-between gap-5 p-6">
			<div>
				<div class="flex flex-wrap items-center gap-3 text-sm text-slate-400">
					<FormattedDate date={date} />
					<span class="h-1 w-1 rounded-full bg-slate-600"></span>
					<span>{readingTime}</span>
				</div>
				<h3 class="mt-4 text-2xl font-semibold tracking-tight text-slate-50 transition group-hover:text-cyan-200">
					{title}
				</h3>
				<p class="mt-3 text-sm leading-7 text-slate-300">{description}</p>
			</div>

			<div class="flex flex-wrap items-center justify-between gap-3">
				<div class="flex flex-wrap gap-2">
					{tags.slice(0, 3).map((tag) => <Tag label={tag} />)}
				</div>
				<span class="text-sm font-medium text-cyan-200">Read article</span>
			</div>
		</div>
	</a>
</article>
