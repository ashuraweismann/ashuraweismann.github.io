---
import { Image } from 'astro:assets';

interface Props {
	title: string;
	category: string;
	image?: any;
	desc: string;
	href?: string;
	eyebrow?: string;
}

const { title, category, image, desc, href = '#', eyebrow = 'Feature story' } = Astro.props;
---

<a class="story-card" href={href}>
	<div class="story-media">
		{image ? (
			<Image src={image} alt={title} widths={[480, 720]} sizes="(max-width: 720px) 100vw, 33vw" />
		) : (
			<div class="story-fallback"></div>
		)}
	</div>

	<div class="story-copy">
		<div class="story-meta">
			<span>{category}</span>
			<span>{eyebrow}</span>
		</div>

		<h3>{title}</h3>
		<p>{desc}</p>
		<span class="story-link">Open article</span>
	</div>
</a>

<style>
	.story-card {
		display: grid;
		grid-template-rows: 220px 1fr;
		height: 100%;
		border-radius: 28px;
		overflow: hidden;
		border: 1px solid rgba(148, 163, 184, 0.14);
		background: linear-gradient(180deg, rgba(15, 26, 45, 0.98), rgba(9, 17, 30, 0.96));
		box-shadow: 0 18px 50px rgba(2, 6, 12, 0.26);
		transform: translateY(0);
		transition:
			transform 220ms ease,
			border-color 220ms ease,
			box-shadow 220ms ease;
	}

	.story-card:hover,
	.story-card:focus-visible {
		transform: translateY(-6px);
		border-color: rgba(87, 230, 255, 0.35);
		box-shadow: 0 26px 70px rgba(2, 6, 12, 0.38);
	}

	.story-media {
		position: relative;
		overflow: hidden;
		background: linear-gradient(135deg, rgba(87, 230, 255, 0.14), rgba(124, 92, 255, 0.22));
	}

	.story-media :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transform: scale(1.01);
		transition: transform 320ms ease;
	}

	.story-card:hover .story-media :global(img) {
		transform: scale(1.06);
	}

	.story-fallback {
		width: 100%;
		height: 100%;
		background:
			radial-gradient(circle at top right, rgba(139, 255, 176, 0.38), transparent 26%),
			linear-gradient(135deg, rgba(87, 230, 255, 0.18), rgba(124, 92, 255, 0.3));
	}

	.story-copy {
		padding: 1.4rem;
		display: grid;
		gap: 0.95rem;
	}

	.story-meta {
		display: flex;
		justify-content: space-between;
		gap: 0.8rem;
		font-size: 0.76rem;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--muted);
	}

	.story-meta span:first-child {
		color: var(--accent);
	}

	h3 {
		margin: 0;
		font-family: var(--heading);
		font-size: 1.45rem;
		line-height: 1.1;
	}

	p {
		margin: 0;
		color: var(--muted);
		font-size: 0.96rem;
		line-height: 1.65;
	}

	.story-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-weight: 700;
		color: var(--text);
	}

	.story-link::after {
		content: "->";
		color: var(--accent);
	}
</style>
