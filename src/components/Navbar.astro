---
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');

const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/about', label: 'About' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/projects', label: 'Projects' },
];

const isActive = (href: string) =>
	href === '/'
		? pathname === '/'
		: pathname === href || pathname.startsWith(`${href}/`);
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-slate-950/70 backdrop-blur-xl">
	<div class="grid-shell">
		<nav class="flex items-center justify-between gap-4 py-4">
			<a href="/" class="group inline-flex items-center gap-3">
				<div
					class="flex h-11 w-11 items-center justify-center rounded-2xl border border-cyan-400/30 bg-cyan-400/10 font-mono text-sm font-bold text-cyan-300 transition group-hover:border-cyan-300 group-hover:bg-cyan-400/20"
				>
					AW
				</div>
				<div>
					<p class="text-sm font-semibold tracking-wide text-slate-50">Ashura Weismann</p>
					<p class="font-mono text-xs uppercase tracking-[0.28em] text-slate-400">
						Engineer / CTF / Blog
					</p>
				</div>
			</a>

			<div class="hidden items-center gap-2 rounded-full border border-white/10 bg-slate-900/70 p-1 md:flex">
				{
					navItems.map((item) => (
						<a
							href={item.href}
							class:list={[
								'rounded-full px-4 py-2 text-sm font-medium transition',
								isActive(item.href)
									? 'bg-cyan-400/15 text-cyan-200'
									: 'text-slate-300 hover:bg-white/5 hover:text-slate-50',
							]}
						>
							{item.label}
						</a>
					))
				}
			</div>

			<a
				href="https://github.com/ashuraweismann"
				target="_blank"
				rel="noreferrer"
				class="hidden rounded-full border border-white/10 px-4 py-2 text-sm font-medium text-slate-300 transition hover:border-cyan-400/40 hover:text-cyan-200 sm:inline-flex"
			>
				GitHub
			</a>
		</nav>

		<div class="flex gap-2 pb-4 md:hidden">
			{
				navItems.map((item) => (
					<a
						href={item.href}
						class:list={[
							'flex-1 rounded-2xl px-3 py-2 text-center text-xs font-medium transition',
							isActive(item.href)
								? 'bg-cyan-400/15 text-cyan-200'
								: 'bg-white/5 text-slate-300 hover:bg-white/10 hover:text-slate-50',
						]}
					>
						{item.label}
					</a>
				))
			}
		</div>
	</div>
</header>
