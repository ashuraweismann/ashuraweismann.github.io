---
import Tag from './Tag.astro';

interface Props {
	name: string;
	description: string;
	techStack: string[];
	github: string;
	demo?: string;
	tags: string[];
	featured?: boolean;
}

const { name, description, techStack, github, demo, tags, featured = false } = Astro.props;
---

<article
	class:list={[
		'panel h-full p-6 transition duration-300 hover:-translate-y-1 hover:border-cyan-400/30',
		featured ? 'ring-1 ring-cyan-400/20' : '',
	]}
>
	<div class="flex h-full flex-col justify-between gap-6">
		<div>
			<div class="flex flex-wrap gap-2">
				{tags.map((tag) => <Tag label={tag} />)}
			</div>
			<h3 class="mt-5 text-2xl font-semibold tracking-tight text-slate-50">{name}</h3>
			<p class="mt-3 text-sm leading-7 text-slate-300">{description}</p>
		</div>

		<div class="space-y-4">
			<div>
				<p class="font-mono text-xs uppercase tracking-[0.24em] text-slate-500">Stack</p>
				<div class="mt-2 flex flex-wrap gap-2">
					{
						techStack.map((tech) => (
							<span class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs text-slate-300">
								{tech}
							</span>
						))
					}
				</div>
			</div>

			<div class="flex flex-wrap gap-3">
				<a
					href={github}
					target="_blank"
					rel="noreferrer"
					class="rounded-full border border-white/10 px-4 py-2 text-sm font-medium text-slate-200 transition hover:border-cyan-400/40 hover:text-cyan-200"
				>
					GitHub
				</a>
				{
					demo && (
						<a
							href={demo}
							target="_blank"
							rel="noreferrer"
							class="rounded-full bg-cyan-400 px-4 py-2 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300"
						>
							Live Demo
						</a>
					)
				}
			</div>
		</div>
	</div>
</article>
