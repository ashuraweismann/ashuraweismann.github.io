---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Tech Blog',
	description = 'A modern tech journal covering tools, product thinking, and the future of software.',
} = Astro.props;
---
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Space+Grotesk:wght@500;700&display=swap"
			rel="stylesheet"
		/>
	</head>

	<body>
		<div class="page-shell">
			<div class="page-glow page-glow-left"></div>
			<div class="page-glow page-glow-right"></div>
			<slot />
		</div>
	</body>
</html>

<style>
	:global(:root) {
		--bg: #07111f;
		--panel: rgba(10, 20, 36, 0.8);
		--panel-strong: rgba(13, 24, 43, 0.94);
		--line: rgba(148, 163, 184, 0.16);
		--text: #e5eefb;
		--muted: #94a8c8;
		--accent: #57e6ff;
		--accent-2: #7c5cff;
		--accent-3: #8bffb0;
		--heading: "Space Grotesk", "Segoe UI", sans-serif;
		--body: "Manrope", "Segoe UI", sans-serif;
	}

	:global(html) {
		background:
			radial-gradient(circle at top, rgba(87, 230, 255, 0.12), transparent 32%),
			radial-gradient(circle at 80% 10%, rgba(124, 92, 255, 0.16), transparent 22%),
			linear-gradient(180deg, #07111f 0%, #02060d 100%);
		color: var(--text);
		scroll-behavior: smooth;
	}

	:global(body) {
		margin: 0;
		font-family: var(--body);
		color: var(--text);
		min-height: 100vh;
	}

	:global(*) {
		box-sizing: border-box;
	}

	:global(a) {
		color: inherit;
		text-decoration: none;
	}

	:global(img) {
		display: block;
		max-width: 100%;
	}

	.page-shell {
		position: relative;
		min-height: 100vh;
		overflow: hidden;
	}

	.page-glow {
		position: absolute;
		border-radius: 999px;
		filter: blur(90px);
		opacity: 0.6;
		pointer-events: none;
	}

	.page-glow-left {
		top: -6rem;
		left: -8rem;
		width: 22rem;
		height: 22rem;
		background: rgba(87, 230, 255, 0.16);
	}

	.page-glow-right {
		top: 9rem;
		right: -5rem;
		width: 18rem;
		height: 18rem;
		background: rgba(124, 92, 255, 0.2);
	}
</style>
