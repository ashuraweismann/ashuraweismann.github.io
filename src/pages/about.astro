---
import AboutHeroImage from '../assets/blog-placeholder-about.jpg';
import Layout from '../layouts/Layout.astro';

const skills = ['Astro', 'TypeScript', 'Tailwind CSS', 'Docker', 'GitHub Actions', 'Linux'];
const interests = ['CTF', 'Web Security', 'DevOps', 'Tooling', 'Writeups', 'Automation'];
---

<Layout
	title="About | Ashura Weismann"
	description="About Ashura Weismann, with a focus on web security, DevOps, developer tooling, and technical writing."
	image={AboutHeroImage}
>
	<section class="grid-shell pt-12 pb-16 sm:pt-16">
		<div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
			<div class="panel px-6 py-10 sm:px-10">
				<p class="section-title">About me</p>
				<h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-50 sm:text-5xl">
					I like building things, breaking assumptions, and documenting what actually worked.
				</h1>
				<p class="mt-6 text-lg leading-8 text-slate-300">
					I use this site as a hybrid portfolio and technical notebook. It collects project work,
					security-oriented experiments, and blog posts that turn rough engineering lessons into
					clear, reusable knowledge.
				</p>
				<p class="mt-4 text-base leading-7 text-slate-400">
					My interests sit at the intersection of developer experience, web security, automation,
					and deployment reliability. I care about fast systems, readable tooling, and writeups that
					feel useful weeks later.
				</p>
			</div>

			<div class="panel overflow-hidden">
				<img src={AboutHeroImage.src} alt="About illustration" class="h-full w-full object-cover" />
			</div>
		</div>

		<div class="mt-8 grid gap-8 lg:grid-cols-3">
			<div class="panel p-6">
				<p class="section-title">Skills</p>
				<div class="mt-5 flex flex-wrap gap-2">
					{
						skills.map((skill) => (
							<span class="rounded-full border border-white/10 bg-white/5 px-3 py-2 text-sm text-slate-200">
								{skill}
							</span>
						))
					}
				</div>
			</div>

			<div class="panel p-6">
				<p class="section-title">Interests</p>
				<div class="mt-5 flex flex-wrap gap-2">
					{
						interests.map((interest) => (
							<span class="rounded-full border border-cyan-400/20 bg-cyan-400/10 px-3 py-2 text-sm text-cyan-200">
								{interest}
							</span>
						))
					}
				</div>
			</div>

			<div class="panel p-6">
				<p class="section-title">Links</p>
				<div class="mt-5 space-y-3 text-sm text-slate-300">
					<a
						href="https://github.com/ashuraweismann"
						target="_blank"
						rel="noreferrer"
						class="block rounded-2xl border border-white/10 px-4 py-3 transition hover:border-cyan-400/40 hover:text-cyan-200"
					>
						GitHub
					</a>
					<a
						href="https://www.linkedin.com"
						target="_blank"
						rel="noreferrer"
						class="block rounded-2xl border border-white/10 px-4 py-3 transition hover:border-cyan-400/40 hover:text-cyan-200"
					>
						LinkedIn
					</a>
					<a
						href="/blog"
						class="block rounded-2xl border border-white/10 px-4 py-3 transition hover:border-cyan-400/40 hover:text-cyan-200"
					>
						Read the blog
					</a>
				</div>
			</div>
		</div>
	</section>
</Layout>
