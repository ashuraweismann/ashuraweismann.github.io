---
import BlogCard from '../../components/BlogCard.astro';
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../../utils/content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout
	title="Blog | Ashura Weismann"
	description="Technical posts, CTF notes, DevOps lessons, and web security writeups."
>
	<section class="grid-shell pt-12 pb-16 sm:pt-16">
		<div class="panel px-6 py-10 sm:px-10">
			<p class="section-title">Technical blog</p>
			<h1 class="mt-4 text-4xl font-semibold tracking-tight text-slate-50 sm:text-5xl">
				Writeups, notes, and engineering breakdowns
			</h1>
			<p class="mt-5 max-w-3xl text-lg leading-8 text-slate-300">
				The blog stays fully static, but the reading experience is upgraded with cleaner metadata,
				tagging, and a layout that works for both security notes and longer engineering posts.
			</p>
		</div>

		<div class="mt-8 grid gap-6 lg:grid-cols-3">
			{
				posts.map((post, index) => (
					<BlogCard
						title={post.data.title}
						description={post.data.description}
						href={`/blog/${post.id}/`}
						date={post.data.pubDate}
						tags={post.data.tags}
						readingTime={getReadingTime(post.body)}
						image={post.data.heroImage}
						featured={index === 0}
					/>
				))
			}
		</div>
	</section>
</Layout>
