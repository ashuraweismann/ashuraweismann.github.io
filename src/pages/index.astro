---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Card from '../components/Card.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredPost = posts[0];
const latestPosts = posts.slice(1, 4);

const labels = ['Editorial deep dive', 'Tooling radar', 'Future stack'];
const categories = ['Frontend systems', 'AI workflows', 'Security notes', 'Developer tools'];
---

<Layout
	title="Tech Blog | Modern software stories"
	description="A modern tech blog with sharp takes on tools, frontend systems, AI workflows, and product craft."
>
	<Navbar />

	<main class="home">
		<section class="hero">
			<div class="hero-copy">
				<span class="eyebrow">Independent tech journal</span>
				<h1>Designing, shipping, and decoding the modern software stack.</h1>
				<p>
					Signal-first writing for developers and product teams who want sharper opinions,
					clearer breakdowns, and fewer recycled headlines.
				</p>

				<div class="hero-actions">
					<a href="/blog" class="primary-action">Browse Articles</a>
					<a href={featuredPost ? `/blog/${featuredPost.id}/` : '/about'} class="secondary-action">
						Read the latest drop
					</a>
				</div>

				<div class="hero-stats">
					<div>
						<strong>{posts.length}</strong>
						<span>Published stories</span>
					</div>
					<div>
						<strong>Weekly</strong>
						<span>Fresh analysis cadence</span>
					</div>
					<div>
						<strong>Human</strong>
						<span>No shallow roundup energy</span>
					</div>
				</div>
			</div>

			<div class="hero-panel">
				<div class="hero-panel-head">
					<span>Featured issue</span>
					<span>Now reading</span>
				</div>

				{featuredPost && (
					<div class="featured-image">
						<Card
							title={featuredPost.data.title}
							category={categories[0]}
							image={featuredPost.data.heroImage}
							desc={featuredPost.data.description}
							href={`/blog/${featuredPost.id}/`}
							eyebrow="Lead story"
						/>
					</div>
				)}
			</div>
		</section>

		<section class="content-strip">
			<div class="section-heading">
				<div>
					<span class="eyebrow">Latest dispatches</span>
					<h2>Readable, visual, and opinionated by design.</h2>
				</div>
				<p>
					Each post is framed like a magazine piece instead of a changelog dump, with more
					context and better pacing for real readers.
				</p>
			</div>

			<div class="story-grid">
				{latestPosts.map((post, index) => (
					<Card
						title={post.data.title}
						category={categories[(index + 1) % categories.length]}
						image={post.data.heroImage}
						desc={post.data.description}
						href={`/blog/${post.id}/`}
						eyebrow={labels[index] ?? 'Story'}
					/>
				))}
			</div>
		</section>

		<section class="insight-band">
			<div class="insight-copy">
				<span class="eyebrow">Why this format works</span>
				<h2>Built for readers who like their tech content with an actual point of view.</h2>
				<p>
					The layout leans editorial: strong hierarchy, generous spacing, and article cards
					that feel closer to a digital magazine than a template starter.
				</p>
			</div>

			<div class="insight-tags">
				<span>AI workflows</span>
				<span>Frontend architecture</span>
				<span>Product strategy</span>
				<span>Developer culture</span>
				<span>Tooling reviews</span>
				<span>Build systems</span>
			</div>
		</section>
	</main>
</Layout>

<style>
	.home {
		position: relative;
		z-index: 1;
		max-width: 1180px;
		margin: 0 auto;
		padding: 2rem 1.25rem 4rem;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
		gap: 1.4rem;
		align-items: stretch;
	}

	.hero-copy,
	.hero-panel,
	.insight-band {
		border: 1px solid rgba(148, 163, 184, 0.14);
		background: linear-gradient(180deg, rgba(10, 20, 36, 0.84), rgba(7, 14, 26, 0.94));
		backdrop-filter: blur(18px);
		box-shadow: 0 28px 80px rgba(2, 6, 12, 0.28);
	}

	.hero-copy {
		padding: 3.2rem;
		border-radius: 34px;
	}

	.eyebrow {
		display: inline-block;
		margin-bottom: 1.1rem;
		color: var(--accent);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.18em;
		text-transform: uppercase;
	}

	h1,
	h2 {
		margin: 0;
		font-family: var(--heading);
		line-height: 0.98;
		letter-spacing: -0.04em;
	}

	h1 {
		max-width: 11ch;
		font-size: clamp(3rem, 8vw, 5.5rem);
	}

	h2 {
		font-size: clamp(2rem, 4vw, 3.1rem);
	}

	.hero-copy > p,
	.section-heading p,
	.insight-copy p {
		color: var(--muted);
		font-size: 1.04rem;
		line-height: 1.75;
	}

	.hero-copy > p {
		max-width: 58ch;
		margin: 1.4rem 0 0;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		margin-top: 2rem;
	}

	.primary-action,
	.secondary-action {
		padding: 0.95rem 1.25rem;
		border-radius: 999px;
		font-weight: 800;
		font-size: 0.95rem;
	}

	.primary-action {
		background: linear-gradient(135deg, var(--accent), #9df5ff);
		color: #05111a;
		box-shadow: 0 14px 34px rgba(87, 230, 255, 0.2);
	}

	.secondary-action {
		border: 1px solid rgba(148, 163, 184, 0.18);
		background: rgba(255, 255, 255, 0.02);
		color: var(--text);
	}

	.hero-stats {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.9rem;
		margin-top: 2.4rem;
	}

	.hero-stats div {
		padding: 1rem;
		border-radius: 22px;
		border: 1px solid rgba(148, 163, 184, 0.12);
		background: rgba(255, 255, 255, 0.025);
	}

	.hero-stats strong,
	.hero-stats span {
		display: block;
	}

	.hero-stats strong {
		font-family: var(--heading);
		font-size: 1.2rem;
	}

	.hero-stats span {
		margin-top: 0.35rem;
		color: var(--muted);
		font-size: 0.88rem;
	}

	.hero-panel {
		padding: 1rem;
		border-radius: 34px;
	}

	.hero-panel-head {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		padding: 0.55rem 0.45rem 1rem;
		color: var(--muted);
		font-size: 0.78rem;
		text-transform: uppercase;
		letter-spacing: 0.16em;
	}

	.featured-story {
		display: block;
	}

	.featured-image :global(.story-card) {
		min-height: 100%;
	}

	.content-strip {
		margin-top: 1.6rem;
	}

	.section-heading {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
		gap: 1.5rem;
		align-items: end;
		margin-bottom: 1.35rem;
		padding: 0.4rem 0.1rem;
	}

	.section-heading p {
		margin: 0;
	}

	.story-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1.25rem;
	}

	.insight-band {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
		gap: 1.4rem;
		margin-top: 1.6rem;
		padding: 2rem;
		border-radius: 30px;
	}

	.insight-copy p {
		margin: 1rem 0 0;
	}

	.insight-tags {
		display: flex;
		flex-wrap: wrap;
		align-content: start;
		gap: 0.8rem;
	}

	.insight-tags span {
		padding: 0.82rem 1rem;
		border-radius: 999px;
		border: 1px solid rgba(148, 163, 184, 0.14);
		background: rgba(255, 255, 255, 0.03);
		color: var(--muted);
		font-size: 0.92rem;
	}

	@media (max-width: 980px) {
		.hero,
		.section-heading,
		.insight-band,
		.story-grid {
			grid-template-columns: 1fr;
		}

		.hero-copy {
			padding: 2.3rem;
		}

		.hero-stats {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 720px) {
		.home {
			padding: 1.1rem 1rem 3rem;
		}

		.hero-copy,
		.hero-panel,
		.insight-band {
			border-radius: 26px;
		}

		.hero-copy {
			padding: 1.5rem;
		}

		.insight-band {
			padding: 1.5rem;
		}
	}
</style>
