---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Card from '../components/Card.astro';
---

<Layout>
  <Navbar />

  <main class="px-6 py-6">

    <h2 class="text-3xl font-bold mb-6">Latest Tech News</h2>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-5">

      <Card
        title="AI is Changing Software Development"
        category="AI"
        image="https://placehold.co/600x400"
        desc="How AI tools are reshaping coding workflows in 2026"
      />

      <Card
        title="Cybersecurity Trends You Must Know"
        category="Security"
        image="https://placehold.co/600x400"
        desc="New attack vectors and defense strategies"
      />

      <Card
        title="Next.js vs Astro in 2026"
        category="Web Dev"
        image="https://placehold.co/600x400"
        desc="Which framework should you choose?"
      />

    </div>

  </main>
</Layout>