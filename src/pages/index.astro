---
import BlogCard from '../components/BlogCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
import { getCollection } from 'astro:content';
import { getReadingTime } from '../utils/content';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const featuredProjects = projects.filter((project) => project.featured).slice(0, 3);
---

<Layout
	title="Ashura Weismann | Developer Portfolio and Tech Blog"
	description="Developer portfolio, technical blog, and CTF writeup hub covering web security, DevOps, and engineering workflows."
>
	<section class="grid-shell pt-12 sm:pt-16">
		<div class="panel overflow-hidden px-6 py-12 sm:px-10 lg:px-12 lg:py-16">
			<div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
				<div>
					<p class="section-title">Developer identity</p>
					<h1 class="mt-4 max-w-3xl text-4xl font-semibold tracking-tight text-slate-50 sm:text-5xl lg:text-6xl">
						I build secure developer tooling and turn the process into useful technical writing.
					</h1>
					<p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">
						This site combines a developer portfolio, engineering blog, and CTF writeup hub for
						documenting projects, security notes, and practical DevOps lessons.
					</p>
					<div class="mt-8 flex flex-wrap gap-3">
						<a
							href="/projects"
							class="rounded-full bg-cyan-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300"
						>
							View Projects
						</a>
						<a
							href="/blog"
							class="rounded-full border border-white/10 px-5 py-3 text-sm font-semibold text-slate-100 transition hover:border-cyan-400/40 hover:text-cyan-200"
						>
							Read Blog
						</a>
					</div>
				</div>

				<div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
					<div class="panel-soft p-5">
						<p class="font-mono text-xs uppercase tracking-[0.28em] text-slate-500">Focus</p>
						<p class="mt-3 text-lg font-semibold text-slate-50">Web security and CTF workflows</p>
					</div>
					<div class="panel-soft p-5">
						<p class="font-mono text-xs uppercase tracking-[0.28em] text-slate-500">Writing</p>
						<p class="mt-3 text-lg font-semibold text-slate-50">Engineering notes with practical depth</p>
					</div>
					<div class="panel-soft p-5">
						<p class="font-mono text-xs uppercase tracking-[0.28em] text-slate-500">Delivery</p>
						<p class="mt-3 text-lg font-semibold text-slate-50">Static, fast, and GitHub Pages friendly</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="grid-shell mt-16">
		<div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
			<div>
				<p class="section-title">Featured projects</p>
				<h2 class="section-heading mt-4">Selected builds from portfolio and lab work</h2>
			</div>
			<a href="/projects" class="text-sm font-medium text-cyan-200 transition hover:text-cyan-100">
				Browse all projects
			</a>
		</div>

		<div class="mt-8 grid gap-6 lg:grid-cols-3">
			{
				featuredProjects.map((project) => (
					<ProjectCard {...project} featured={true} />
				))
			}
		</div>
	</section>

	<section class="grid-shell mt-16 pb-16">
		<div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
			<div>
				<p class="section-title">Latest blog posts</p>
				<h2 class="section-heading mt-4">Fresh notes, writeups, and technical breakdowns</h2>
			</div>
			<a href="/blog" class="text-sm font-medium text-cyan-200 transition hover:text-cyan-100">
				Visit the blog
			</a>
		</div>

		<div class="mt-8 grid gap-6 lg:grid-cols-3">
			{
				posts.map((post, index) => (
					<BlogCard
						title={post.data.title}
						description={post.data.description}
						href={`/blog/${post.id}/`}
						date={post.data.pubDate}
						tags={post.data.tags}
						readingTime={getReadingTime(post.body)}
						image={post.data.heroImage}
						featured={index === 0}
					/>
				))
			}
		</div>
	</section>
</Layout>
